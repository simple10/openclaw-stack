{
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "gateway": {
    "bind": "lan",
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_TOKEN}}"
    },
    "remote": {
      "token": "{{GATEWAY_TOKEN}}"
    },
    "trustedProxies": [
      "172.30.0.1"
    ],
    "controlUi": {
      "basePath": "{{OPENCLAW_DOMAIN_PATH}}"
    }
  },
  "logging": {
    "consoleStyle": "json",
    "redactSensitive": "tools"
  },
  "models": {
    "mode": "merge",
    "providers": {
      // Built-in providers — baseUrl overrides the default endpoint
      "anthropic": {
        "baseUrl": "{{AI_GATEWAY_WORKER_URL}}",
        "apiKey": "{{AI_GATEWAY_AUTH_TOKEN}}"
      },
      "openai": {
        "baseUrl": "{{AI_GATEWAY_WORKER_URL}}/v1",
        "apiKey": "{{AI_GATEWAY_AUTH_TOKEN}}"
      }
      // OpenRouter for access to everything else
      // "openrouter": {
      //   "baseUrl": "{{AI_GATEWAY_WORKER_URL}}/api/v1",
      //   "apiKey": "{{AI_GATEWAY_AUTH_TOKEN}}"
      // }
    },
    // Aliases — short names for full provider/model refs
    "aliases": {
      "sonnet": "anthropic/claude-sonnet-4-5-20250929",
      "opus": "anthropic/claude-opus-4-6",
      "haiku": "anthropic/claude-haiku-4-5-20251001",
      "gpt": "openai/gpt-5.2",
      "gpt-codex": "gpt-5.2-codex"
      // "qwen": "ollama/qwen2.5:32b",
      // "llama": "ollama/llama3.3:70b",
      // "deepseek": "vllm/deepseek-r1-70b",
      // "kimi": "openrouter/moonshotai/kimi-k2"
    },
    "agents": {
      "defaults": {
        "sandbox": {
          "mode": "all",
          "scope": "agent",
          "docker": {
            "image": "openclaw-sandbox:bookworm-slim",
            "containerPrefix": "openclaw-sbx-",
            "workdir": "/workspace",
            "readOnlyRoot": true,
            "tmpfs": [
              "/tmp",
              "/var/tmp",
              "/run"
            ],
            "network": "none",
            "user": "1000:1000",
            "capDrop": [
              "ALL"
            ],
            "env": {
              "LANG": "C.UTF-8",
              "PATH": "/opt/skill-bins:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
            },
            "pidsLimit": 256,
            "memory": "1g",
            "memorySwap": "2g",
            "cpus": 1,
            "binds": [
              "/opt/skill-bins:/opt/skill-bins:ro"
            ]
          },
          "browser": {
            "enabled": true,
            "image": "openclaw-sandbox-browser:bookworm-slim",
            "containerPrefix": "openclaw-sbx-browser-",
            "cdpPort": 9222,
            "vncPort": 5900,
            "noVncPort": 6080,
            "headless": false,
            "enableNoVnc": true,
            "autoStart": true,
            "autoStartTimeoutMs": 12000
          },
          "prune": {
            "idleHours": 168,
            "maxAgeDays": 60
          }
        },
        "model": {
          "primary": "sonnet",
          "fallbacks": [
            "gpt",
            "haiku"
          ]
        }
      },
      "list": [
        {
          "id": "main",
          "default": true,
          "subagents": {
            "allowAgents": [
              "code",
              "skills"
            ]
          }
        },
        {
          "id": "code",
          "name": "Code Agent",
          "sandbox": {
            "docker": {
              "image": "openclaw-sandbox-claude:bookworm-slim",
              "tmpfs": [
                "/tmp",
                "/var/tmp",
                "/run",
                "/home/linuxbrew:uid=1000,gid=1000"
              ],
              "network": "bridge",
              "memory": "2g",
              "memorySwap": "4g",
              "cpus": 2,
              "binds": [
                "/home/node/.claude-sandbox:/home/linuxbrew/.claude",
                "/opt/skill-bins:/opt/skill-bins:ro"
              ]
            }
          },
          "model": {
            "primary": "opus",
            "fallbacks": [
              "gpt-codex",
              "sonnet",
              "gpt"
            ]
          }
        },
        {
          "id": "skills",
          "name": "Skills Agent",
          "sandbox": {
            "docker": {
              "image": "openclaw-sandbox-common:bookworm-slim",
              "network": "bridge",
              "memory": "1g",
              "memorySwap": "2g",
              "cpus": 1
            }
          }
        }
      ]
    },
    "tools": {
      "sandbox": {
        "tools": {
          "allow": [
            "exec",
            "process",
            "read",
            "write",
            "edit",
            "apply_patch",
            "browser",
            "sessions_list",
            "sessions_history",
            "sessions_send",
            "sessions_spawn",
            "session_status"
          ],
          "deny": [
            "canvas",
            "nodes",
            "cron",
            "discord",
            "gateway"
          ]
        }
      }
    }
  }
}
