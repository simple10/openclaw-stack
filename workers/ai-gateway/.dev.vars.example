# Copy to .dev.vars and fill in real values

# Level of logs to console.log in the Cloudflare Worker
LOG_LEVEL=debug

# Admin token — protects /admin/* endpoints for user CRUD
ADMIN_AUTH_TOKEN=your-admin-token

# User tokens and provider credentials are stored in AUTH_KV (Cloudflare KV).
# Create namespace: wrangler kv namespace create AUTH_KV
# Manage users via admin endpoints (see plan docs).

# Egress proxy — routes requests through VPS IP to bypass upstream WAF blocks
# Set these when chatgpt.com (openai-codex) blocks Cloudflare Worker IPs
EGRESS_PROXY_URL=                     # e.g. https://egress-proxy.yourdomain.com
EGRESS_PROXY_AUTH_TOKEN=              # Shared secret with the VPS egress proxy sidecar

# Cloudflare AI Gateway integration (optional)
# When configured, provider requests are sent to Cloudflare AI Gateway instead of directly to the provider
CF_AI_GATEWAY_ID=openclaw-ai-gateway    # Name of the gateway
CF_AI_GATEWAY_ACCOUNT_ID=               # Use `wrangler whoami` to get account ID
CF_AI_GATEWAY_TOKEN=                    # Cloudflare AI Gateway auth token

# LLM telemetry via llmetry (opt-in — set LLMETRY_ENABLED=true and provide endpoint/token)
LLMETRY_ENABLED=false
LLMETRY_ENDPOINT=               # URL of log receiver /llmetry endpoint
LLMETRY_AUTH_TOKEN=              # Bearer token for log receiver auth
